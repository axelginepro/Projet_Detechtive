      "containerId": "kali"
    },
    {
      "id": "pfsense",
      "type": "rectangle",
      "x": 230, "y": 170,
      "width": 480, "height": 100,
      "strokeColor": "#1971c2", "backgroundColor": "#d0ebff",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100,
      "boundElements": [{ "type": "text", "id": "pf_lbl" }]
    },
    {
      "id": "pf_lbl",
      "type": "text",
      "x": 240, "y": 178,
      "width": 460, "height": 85,
      "text": "pfSense — Pare-feu / NAT / VPN / Router-on-a-Stick\nWAN : IP Opérateur\nSous-interfaces VLAN 10/20/30/40/50 (dot1q trunk)\nDHCP, DNS, Firewall inter-VLAN",
      "fontSize": 12, "textAlign": "center", "verticalAlign": "middle",
      "containerId": "pfsense"
    },
    {
      "id": "trunk_lbl",
      "type": "text",
      "x": 450, "y": 292,
      "width": 220, "height": 18,
      "text": "Trunk 802.1q — VLAN 10,20,30,40,50",
      "fontSize": 11, "textAlign": "center", "verticalAlign": "middle",
      "strokeColor": "#2f9e44",
      "containerId": null
    },
    {
      "id": "switch",
      "type": "rectangle",
      "x": 230, "y": 330,
      "width": 480, "height": 95,
      "strokeColor": "#2f9e44", "backgroundColor": "#ebfbee",
      "fillStyle": "solid", "strokeWidth": 2, "roughness": 1, "opacity": 100,
      "boundElements": [{ "type": "text", "id": "sw_lbl" }]
    },
    {
      "id": "sw_lbl",
      "type": "text",
      "x": 240, "y": 338,
      "width": 460, "height": 80,
      "text": "IOU — Switch L2 (no ip routing)\nTrunk eth0/0 → pfSense (VLAN 10,20,30,40,50)\nPorts access : eth0/1-2 (VLAN10) | eth1/0-1 (VLAN20)\neth3/2 (VLAN30) | eth0/3 (VLAN40) | eth1/2-3 (VLAN50)\nPorts inutilisés → VLAN 999 (shutdown)",
      "fontSize": 12, "textAlign": "center", "verticalAlign": "middle",
      "containerId": "switch"
    },
    {
      "id": "dmz",
      "type": "rectangle",
      "x": -300, "y": 510,
      "width": 270, "height": 210,
